{#
  Custom landing-page index for ephys_acquisition docs.
  Dark oscilloscope-inspired theme — precision instrument aesthetic.
#}
{% if root_module_name %}
<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="refresh" content="0; url=./{{ root_module_name.replace(".","/") }}.html"/>
</head>
</html>
{% else %}
{% extends "frame.html.jinja2" %}

{% block title %}ephys_acquisition — API Documentation{% endblock %}

{% block style %}
    {{ super() | safe }}
    <style>
    /* ── Fonts ── */
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@400;500;600&display=swap');

    /* ── Palette ── */
    :root {
        --bg-deep:      #080c14;
        --bg-surface:   #0f1520;
        --bg-card:      #151d2e;
        --bg-elevated:  #1a2540;
        --border:       #1e2d4a;
        --border-light: #2a3d5c;
        --text-primary:   #e2e8f0;
        --text-secondary: #8896ab;
        --text-dim:       #556377;
        --accent-cyan:    #22d3ee;
        --accent-amber:   #f59e0b;
        --accent-rose:    #f472b6;
        --accent-green:   #34d399;
        --accent-violet:  #a78bfa;
    }

    /* ── Global ── */
    html, body {
        background: var(--bg-deep) !important;
    }

    main.pdoc {
        padding-top: 0;
        padding-right: 0;
        padding-bottom: 0;
        overflow: hidden;
        background: var(--bg-deep);
        border-radius: 0;
    }

    /* ── Nav sidebar ── */
    nav.pdoc {
        background: var(--bg-surface);
        border-right: 1px solid var(--border);
    }
    nav.pdoc a, nav.pdoc h2 { color: var(--text-secondary) !important; }
    nav.pdoc a:hover { background: rgba(34, 211, 238, 0.06); border-radius: 6px; color: var(--accent-cyan) !important; }
    nav.pdoc h2 {
        font-family: 'Syne', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-dim) !important;
    }
    nav.pdoc input[type=search] {
        background: rgba(34, 211, 238, 0.04);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-primary);
    }
    nav.pdoc input[type=search]:focus {
        border-color: rgba(34, 211, 238, 0.3);
        box-shadow: 0 0 0 3px rgba(34, 211, 238, 0.08);
        outline: none;
    }

    /* ══════════════════════════════════════════════════════════════════════
       HERO SECTION — animated waveform + gradient
       ══════════════════════════════════════════════════════════════════════ */
    .hero {
        position: relative;
        background: linear-gradient(160deg, #080c14 0%, #0c1a2e 40%, #0f1520 100%);
        padding: 4rem 3rem 3.5rem;
        overflow: hidden;
        border-bottom: 1px solid var(--border);
    }

    /* Animated SVG waveform background */
    .hero-waveform {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0.12;
        pointer-events: none;
    }
    .hero-waveform .trace-1 {
        stroke: var(--accent-cyan);
        stroke-width: 2;
        fill: none;
        stroke-dasharray: 1200;
        stroke-dashoffset: 1200;
        animation: traceDraw 3s ease-out 0.3s forwards;
    }
    .hero-waveform .trace-2 {
        stroke: var(--accent-amber);
        stroke-width: 1.5;
        fill: none;
        stroke-dasharray: 1200;
        stroke-dashoffset: 1200;
        animation: traceDraw 3.5s ease-out 0.8s forwards;
    }
    .hero-waveform .trace-3 {
        stroke: var(--accent-rose);
        stroke-width: 1;
        fill: none;
        stroke-dasharray: 1200;
        stroke-dashoffset: 1200;
        animation: traceDraw 4s ease-out 1.2s forwards;
    }

    @keyframes traceDraw {
        to { stroke-dashoffset: 0; }
    }

    /* Grid overlay */
    .hero-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(34, 211, 238, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(34, 211, 238, 0.03) 1px, transparent 1px);
        background-size: 40px 40px;
        pointer-events: none;
    }

    /* Glow orbs */
    .hero::before {
        content: '';
        position: absolute;
        top: -120px; right: 10%;
        width: 400px; height: 400px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(34, 211, 238, 0.08) 0%, transparent 70%);
        pointer-events: none;
    }
    .hero::after {
        content: '';
        position: absolute;
        bottom: -80px; left: 5%;
        width: 300px; height: 300px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(245, 158, 11, 0.05) 0%, transparent 70%);
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        z-index: 1;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(34, 211, 238, 0.06);
        border: 1px solid rgba(34, 211, 238, 0.15);
        border-radius: 100px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.06em;
        padding: 0.3rem 1rem;
        margin-bottom: 1.5rem;
        color: var(--accent-cyan);
    }
    .hero-badge .dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: var(--accent-green);
        box-shadow: 0 0 6px rgba(52, 211, 153, 0.6);
        animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.8); }
    }

    .hero h1 {
        font-family: 'Syne', sans-serif;
        font-size: 3rem;
        font-weight: 800;
        margin: 0 0 0.5rem;
        line-height: 1.1;
        color: #fff;
        border: none;
        letter-spacing: -0.02em;
    }
    .hero h1::before { display: none; }

    .hero h1 .highlight {
        background: linear-gradient(135deg, var(--accent-cyan), var(--accent-green));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero .subtitle {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.1rem;
        font-weight: 400;
        color: var(--text-secondary);
        margin-bottom: 2rem;
        max-width: 560px;
        line-height: 1.7;
    }

    /* Hero search */
    .hero-search {
        display: flex;
        align-items: center;
        max-width: 440px;
        position: relative;
    }
    .hero-search input[type=search] {
        width: 100%;
        background: rgba(15, 21, 32, 0.7);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--border-light);
        border-radius: 12px;
        color: var(--text-primary);
        font-family: 'DM Sans', sans-serif;
        font-size: 0.95rem;
        outline: none;
        padding: 0.7rem 1rem 0.7rem 2.6rem;
        transition: border-color 0.25s, box-shadow 0.25s;
    }
    .hero-search input[type=search]::placeholder { color: var(--text-dim); }
    .hero-search input[type=search]:focus {
        border-color: rgba(34, 211, 238, 0.4);
        box-shadow: 0 0 0 4px rgba(34, 211, 238, 0.06), 0 0 20px rgba(34, 211, 238, 0.08);
    }
    .hero-search .search-icon {
        position: absolute;
        left: 0.85rem;
        color: var(--text-dim);
        pointer-events: none;
        font-size: 0.95rem;
    }

    /* Stat pills */
    .hero-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-top: 2rem;
    }
    .hero-stat {
        font-family: 'IBM Plex Mono', monospace;
        background: rgba(34, 211, 238, 0.04);
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 0.75rem;
        color: var(--text-dim);
        padding: 0.3rem 0.75rem;
        letter-spacing: 0.02em;
        transition: border-color 0.2s, color 0.2s;
    }
    .hero-stat:hover {
        border-color: var(--border-light);
        color: var(--text-secondary);
    }
    .hero-stat strong {
        color: var(--accent-cyan);
        font-weight: 600;
    }

    /* ══════════════════════════════════════════════════════════════════════
       LANDING BODY
       ══════════════════════════════════════════════════════════════════════ */
    .landing-body {
        padding: 3rem 3rem 2rem;
    }

    /* Section headings */
    .section-label {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent-cyan);
        margin-bottom: 0.6rem;
        opacity: 0.7;
    }
    .section-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 0.4rem;
        letter-spacing: -0.01em;
    }
    .section-desc {
        color: var(--text-secondary);
        font-size: 0.92rem;
        margin-bottom: 1.75rem;
        line-height: 1.65;
    }

    /* ── Module cards grid ── */
    .module-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1rem;
        margin-bottom: 3rem;
    }
    .module-card {
        position: relative;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.5rem 1.4rem 1.25rem;
        text-decoration: none !important;
        color: inherit;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        transition: border-color 0.25s, box-shadow 0.25s, transform 0.2s;
        overflow: hidden;
    }
    .module-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--card-accent, var(--accent-cyan)), transparent);
        opacity: 0;
        transition: opacity 0.3s;
    }
    .module-card:hover {
        border-color: var(--border-light);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 24px rgba(34, 211, 238, 0.04);
        transform: translateY(-3px);
    }
    .module-card:hover::before {
        opacity: 1;
    }

    .module-card-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        margin-bottom: 0.3rem;
        background: var(--icon-bg, rgba(34, 211, 238, 0.08));
        border: 1px solid var(--icon-border, rgba(34, 211, 238, 0.15));
    }
    .module-card-name {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--text-primary);
    }
    .module-card-desc {
        font-size: 0.82rem;
        color: var(--text-secondary);
        line-height: 1.6;
        flex: 1;
    }
    .module-card-desc code {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: 3px;
        padding: 0.05em 0.3em;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.78rem;
        color: var(--accent-cyan);
    }
    .module-card-arrow {
        font-family: 'IBM Plex Mono', monospace;
        color: var(--text-dim);
        font-size: 0.8rem;
        align-self: flex-end;
        transition: color 0.2s, transform 0.2s;
    }
    .module-card:hover .module-card-arrow {
        color: var(--accent-cyan);
        transform: translateX(3px);
    }

    /* Card accent colors */
    .card-config    { --card-accent: var(--accent-amber); --icon-bg: rgba(245, 158, 11, 0.08); --icon-border: rgba(245, 158, 11, 0.15); }
    .card-acq       { --card-accent: var(--accent-cyan);  --icon-bg: rgba(34, 211, 238, 0.08); --icon-border: rgba(34, 211, 238, 0.15); }
    .card-hardware  { --card-accent: var(--accent-green);  --icon-bg: rgba(52, 211, 153, 0.08); --icon-border: rgba(52, 211, 153, 0.15); }
    .card-ui        { --card-accent: var(--accent-violet); --icon-bg: rgba(167, 139, 250, 0.08); --icon-border: rgba(167, 139, 250, 0.15); }
    .card-utils     { --card-accent: var(--accent-rose);   --icon-bg: rgba(244, 114, 182, 0.08); --icon-border: rgba(244, 114, 182, 0.15); }

    /* ── Quick-start code block ── */
    .quickstart {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.5rem 1.75rem;
        margin-bottom: 3rem;
        position: relative;
    }
    .quickstart::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--accent-cyan), transparent);
        opacity: 0.3;
    }
    .quickstart p {
        font-size: 0.88rem;
        color: var(--text-secondary);
        margin: 0 0 0.75rem;
    }
    .quickstart p code {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: 3px;
        padding: 0.1em 0.35em;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.8rem;
        color: var(--accent-cyan);
    }
    .quickstart pre {
        background: var(--bg-deep);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text-secondary);
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.82rem;
        line-height: 1.8;
        margin: 0;
        overflow-x: auto;
        padding: 1.25rem 1.5rem;
    }
    .quickstart pre .cm { color: #4a6178; font-style: italic; }
    .quickstart pre .kw { color: var(--accent-rose); }
    .quickstart pre .fn { color: var(--accent-cyan); }
    .quickstart pre .st { color: var(--accent-green); }
    .quickstart pre .nb { color: var(--accent-amber); }

    /* ── Concept / feature cards ── */
    .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 0.85rem;
        margin-bottom: 3rem;
    }
    .feature-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.15rem 1.25rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .feature-card:hover {
        border-color: var(--border-light);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    }
    .feature-card-title {
        font-family: 'Syne', sans-serif;
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.4rem;
    }
    .feature-card-body {
        font-size: 0.78rem;
        color: var(--text-secondary);
        line-height: 1.6;
    }
    .feature-card-body strong {
        color: var(--accent-amber);
        font-weight: 600;
    }
    .feature-card-body code {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: 3px;
        padding: 0.05em 0.3em;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.72rem;
        color: var(--accent-cyan);
    }

    /* ── Divider ── */
    .section-divider {
        border: none;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--border-light), transparent);
        margin: 0.5rem 0 2.5rem;
    }

    /* ── Footer ── */
    .landing-footer {
        border-top: 1px solid var(--border);
        color: var(--text-dim);
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.02em;
        padding: 1.5rem 0 0.5rem;
        text-align: center;
    }
    .landing-footer a {
        color: var(--accent-cyan);
        text-decoration: none;
        transition: color 0.15s;
    }
    .landing-footer a:hover { color: #67e8f9; }

    /* ── Staggered fade-in animations ── */
    @keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .animate-in {
        opacity: 0;
        animation: fadeSlideUp 0.5s ease-out forwards;
    }
    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }
    .delay-3 { animation-delay: 0.3s; }
    .delay-4 { animation-delay: 0.4s; }
    .delay-5 { animation-delay: 0.5s; }
    .delay-6 { animation-delay: 0.6s; }
    .delay-7 { animation-delay: 0.7s; }

    /* ── Responsive ── */
    @media (max-width: 700px) {
        .hero { padding: 2.5rem 1.5rem 2rem; }
        .hero h1 { font-size: 2rem; }
        .landing-body { padding: 2rem 1.25rem 1.5rem; }
        .module-grid { grid-template-columns: 1fr; }
    }
    </style>
{% endblock %}

{% block nav %}
    <h2>Modules</h2>
    <ul>
        {% for submodule in all_modules if "._" not in submodule and not submodule.startswith("_") %}
            <li><a href="{{ submodule.replace(".","/") }}.html">{{ submodule }}</a></li>
        {% endfor %}
    </ul>
{% endblock %}

{% block content %}
<main class="pdoc">

    <!-- ══ Hero ══════════════════════════════════════════════════════════ -->
    <div class="hero">

        <!-- Oscilloscope grid overlay -->
        <div class="hero-grid"></div>

        <!-- Animated waveform traces (neural spike + sine + noise) -->
        <svg class="hero-waveform" viewBox="0 0 1200 300" preserveAspectRatio="none">
            <!-- Trace 1: Neural spike / action potential waveform -->
            <path class="trace-1" d="M0,180 L80,180 L100,178 L120,175 L140,180 L160,180
                L200,182 L220,180 L240,178 L280,180
                L300,176 L310,170 L315,120 L318,60 L320,30 L322,60 L325,140 L330,200 L335,220 L340,210 L350,185 L360,180
                L400,180 L440,178 L480,180
                L520,176 L530,170 L535,115 L538,50 L540,20 L542,55 L545,140 L550,205 L555,225 L560,212 L570,185 L580,180
                L620,180 L660,182 L700,180
                L740,178 L750,172 L755,125 L758,65 L760,35 L762,65 L765,145 L770,202 L775,218 L780,208 L790,184 L800,180
                L840,180 L880,178 L920,180 L960,182 L1000,180
                L1020,176 L1030,168 L1035,110 L1038,45 L1040,15 L1042,50 L1045,138 L1050,208 L1055,228 L1060,215 L1070,186 L1080,180
                L1120,180 L1160,178 L1200,180" />
            <!-- Trace 2: Slow oscillation / membrane potential -->
            <path class="trace-2" d="M0,200 C100,200 150,170 200,175 S300,210 400,195
                S500,165 600,180 S700,215 800,190 S900,160 1000,185 S1100,210 1200,195" />
            <!-- Trace 3: High-frequency noise / fast oscillation -->
            <path class="trace-3" d="M0,240 L20,238 L40,244 L60,236 L80,242 L100,237
                L120,243 L140,235 L160,241 L180,238 L200,244 L220,236 L240,242
                L260,237 L280,243 L300,235 L320,241 L340,238 L360,244 L380,236
                L400,242 L420,237 L440,243 L460,235 L480,241 L500,238 L520,244
                L540,236 L560,242 L580,237 L600,243 L620,235 L640,241 L660,238
                L680,244 L700,236 L720,242 L740,237 L760,243 L780,235 L800,241
                L820,238 L840,244 L860,236 L880,242 L900,237 L920,243 L940,235
                L960,241 L980,238 L1000,244 L1020,236 L1040,242 L1060,237
                L1080,243 L1100,235 L1120,241 L1140,238 L1160,244 L1180,236 L1200,240" />
        </svg>

        <div class="hero-content">
            <div class="hero-badge animate-in delay-1">
                <span class="dot"></span>
                NI PCIe-6323 &middot; PySide6 &middot; Python
            </div>

            <h1 class="animate-in delay-2">
                ephys<span class="highlight">_acquisition</span>
            </h1>

            <p class="subtitle animate-in delay-3">
                Real-time whole-cell electrophysiology — continuous and trial-based
                acquisition, live waveform display, and HDF5 data archiving.
            </p>

            {% if search %}
            <div class="hero-search animate-in delay-4">
                <span class="search-icon">&#9906;</span>
                <input type="search" placeholder="Search API docs..." aria-label="search box">
            </div>
            {% endif %}

            <div class="hero-stats animate-in delay-5">
                <span class="hero-stat"><strong>6</strong> packages</span>
                <span class="hero-stat"><strong>20 kS/s</strong> sample rate</span>
                <span class="hero-stat"><strong>CC &amp; VC</strong> clamp modes</span>
                <span class="hero-stat"><strong>HDF5</strong> output</span>
                <span class="hero-stat"><strong>Basler</strong> camera sync</span>
            </div>
        </div>
    </div>

    <!-- ══ Body ══════════════════════════════════════════════════════════ -->
    <div class="landing-body">

        <!-- ── Module cards ── -->
        <p class="section-label animate-in delay-5">API Reference</p>
        <h2 class="section-title animate-in delay-5">Browse Packages</h2>
        <p class="section-desc animate-in delay-6">
            Full module reference — classes, functions, parameters, and signals.
        </p>

        <div class="module-grid">
            <a class="module-card card-config animate-in delay-5" href="config.html">
                <div class="module-card-icon">&#9881;&#65039;</div>
                <div class="module-card-name">config</div>
                <div class="module-card-desc">
                    Global constants — channel map, sample rate, AO scaling
                    (<code>400 pA/V</code> CC, <code>20 mV/V</code> VC), and the
                    <code>ChannelDef</code> type alias.
                </div>
                <div class="module-card-arrow">&rarr;</div>
            </a>
            <a class="module-card card-acq animate-in delay-5" href="acquisition/continuous_mode.html">
                <div class="module-card-icon">&#9126;</div>
                <div class="module-card-name">acquisition</div>
                <div class="module-card-desc">
                    Continuous &amp; trial-based controllers, data savers (HDF5),
                    trial protocol definitions, and waveform builders.
                </div>
                <div class="module-card-arrow">&rarr;</div>
            </a>
